{
  "reflection_interval": 3600,
  "confidence_threshold": 0.3,
  "track_capabilities": true,
  "track_confidence": true,
  "track_knowledge": true,
  "confidence_weights": {
    "evidence_quality": 0.3,
    "consistency": 0.25,
    "source_reliability": 0.2,
    "recency": 0.15,
    "source_count": 0.1
  },
  "reflection_types": {
    "capability": {
      "triggers": ["skill_used", "skill_failed", "new_skill_discovered"],
      "frequency": "on_event"
    },
    "confidence": {
      "triggers": ["decision_made", "prediction_made", "belief_updated"],
      "frequency": "on_event"
    },
    "decision": {
      "triggers": ["deliberation_complete", "vote_cast", "consensus_reached"],
      "frequency": "on_event"
    },
    "blind_spot": {
      "triggers": ["unknown_encountered", "capability_gap", "unexpected_outcome"],
      "frequency": "on_event"
    }
  },
  "logging": {
    "level": "info",
    "file": "self-model.log"
  }
}