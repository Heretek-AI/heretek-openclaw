{
    "loop_interval": 30,
    "think_time_budget": 10,
    "broadcast_thoughts": false,
    "relevance_threshold": 0.5,
    "urgency_threshold": 0.6,
    "enabled_for_agents": [
        "steward",
        "alpha",
        "beta",
        "charlie",
        "examiner",
        "explorer",
        "sentinel",
        "coder"
    ],
    "delta_detector": {
        "workspace_root": "/workspace",
        "curiosity_dir": "/workspace/.curiosity",
        "check_files": true,
        "check_databases": true,
        "check_external": true,
        "check_agents": true,
        "file_patterns": ["*.md", "*.json", "*.js", "*.sh"],
        "important_dirs": ["", "/memory", "/skills", "/.curiosity"]
    },
    "relevance_scorer": {
        "score_threshold": 0.5,
        "weights": {
            "file_created": 0.7,
            "file_modified": 0.6,
            "file_deleted": 0.8,
            "db_modified": 0.5,
            "external_cve": 0.9,
            "external_release": 0.6,
            "external_opportunity": 0.5,
            "agent_heartbeat": 0.3,
            "agent_offline": 0.9,
            "agent_online": 0.4
        }
    },
    "thought_generator": {
        "idle_thinking_enabled": true,
        "max_idle_thoughts": 3,
        "confidence_defaults": {
            "file_created": 0.7,
            "file_modified": 0.6,
            "db_modified": 0.5,
            "external_cve": 0.8,
            "external_release": 0.6,
            "agent_heartbeat": 0.9,
            "agent_offline": 0.9,
            "idle": 0.5
        }
    },
    "action_urgency": {
        "urgency_threshold": 0.6,
        "thresholds": {
            "trigger_deliberation": 0.7,
            "broadcast_thought": 0.5,
            "trigger_failover_vote": 0.9,
            "update_context": 0.4,
            "evaluate_update": 0.6,
            "check_consensus": 0.5,
            "log_for_review": 0.0
        }
    },
    "logging": {
        "log_file": "/var/log/thought-loop.log",
        "log_level": "info",
        "console_output": true
    },
    "state": {
        "state_file": "/tmp/thought-loop-state.json",
        "delta_state_file": "/tmp/delta-detector-state.json",
        "max_history": 100
    }
}
