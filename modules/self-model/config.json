{
    "reflection_interval": 3600,
    "confidence_threshold": 0.3,
    "track_capabilities": true,
    "track_knowledge": true,
    "track_blind_spots": true,
    "state_file": "self-model-state.json",
    "capability_file": "capabilities.json",
    "auto_discover_skills": true,
    "auto_discover_tools": true,
    "confidence_weights": {
        "evidence_quality": 0.3,
        "consistency": 0.25,
        "source_reliability": 0.2,
        "recency": 0.15,
        "source_count": 0.1
    },
    "reflection_types": [
        "capability",
        "confidence",
        "decision",
        "blind_spot"
    ],
    "metrics": {
        "max_reflections": 50,
        "max_trend_entries": 20,
        "confidence_delta_on_success": 0.05,
        "confidence_delta_on_failure": -0.1
    }
}