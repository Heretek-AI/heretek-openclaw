# ==============================================================================
# Heretek OpenClaw — Agent Container
# ==============================================================================
# This Dockerfile creates a container for each OpenClaw agent.
# Each agent connects to LiteLLM via passthrough endpoint (agent/{name})
# Model assignment is managed in LiteLLM WebUI, not here.
#
# Build: docker build --build-arg AGENT_NAME=steward -t heretek-agent:steward .
# Run:   docker run -d --name heretek-steward heretek-agent:steward
#
# Runtime volumes (mounted via docker-compose):
#   - ./agents/{name}:/app/agent:ro        - Agent-specific identity files
#   - ./agents/entrypoint.sh:/app/entrypoint.sh:ro  - Runtime entrypoint
#   - ./agents/lib:/app/lib:ro             - Agent client library
#   - ../heretek-skills/skills:/app/skills:ro      - Skills repository
#   - ./modules:/app/modules:ro            - Autonomy modules
# ==============================================================================

# Base image with Node.js and essential tools
FROM node:20-alpine AS base

# Build argument for agent name
ARG AGENT_NAME=steward

# Install system dependencies
RUN apk add --no-cache \
    curl \
    bash \
    git \
    jq \
    netcat-openbsd \
    && rm -rf /var/cache/apk/*

# Create app directory structure
WORKDIR /app
RUN mkdir -p /app/agent /app/lib /app/skills /app/modules /app/state /app/memory /app/collective

# Copy agent client library (will be overwritten by volume mount at runtime)
COPY agents/lib/ /app/lib/

# Create the runtime entrypoint script
# This will be overwritten by the volume mount at runtime
RUN echo '#!/bin/bash' > /app/entrypoint.sh && \
    echo 'set -e' >> /app/entrypoint.sh && \
    echo 'echo "Starting agent: $AGENT_NAME"' >> /app/entrypoint.sh && \
    echo 'exec bash' >> /app/entrypoint.sh && \
    chmod +x /app/entrypoint.sh

# Create health check endpoint script
RUN echo '#!/bin/bash' > /app/healthcheck.sh && \
    echo 'curl -f http://localhost:8000/health 2>/dev/null || echo "Health check failed"' >> /app/healthcheck.sh && \
    chmod +x /app/healthcheck.sh

# Create package.json for Node.js dependencies
RUN echo '{ \
  "name": "heretek-agent", \
  "version": "2.0.0", \
  "description": "Heretek OpenClaw Agent", \
  "main": "index.js", \
  "scripts": { \
    "start": "bash /app/entrypoint.sh", \
    "health": "bash /app/healthcheck.sh" \
  }, \
  "dependencies": { \
    "ioredis": "^5.3.2", \
    "langfuse": "^3.0.0" \
  }, \
  "engines": { \
    "node": ">=20.0.0" \
  } \
}' > /app/package.json

# Install Node.js dependencies
RUN npm install --production

# Set environment variables
ENV NODE_ENV=production
ENV AGENT_PORT=8000
ENV AGENT_NAME=${AGENT_NAME}
ENV SKILLS_PATH=/app/skills
ENV AGENT_LOOP_INTERVAL=30

# Expose port for health check and agent communication
EXPOSE 8000

# Health check
HEALTHCHECK --interval=30s --timeout=10s --retries=3 \
    CMD curl -f http://localhost:8000/health 2>/dev/null || exit 1

# Start agent using the entrypoint script
# The entrypoint.sh is mounted at runtime via docker-compose
CMD ["/bin/bash", "/app/entrypoint.sh"]
