{
  "name": "minimal",
  "description": "Minimal installation without systemd or skills",
  "openclaw": {
    "version": "2026.3.23-2"
  },
  "liberation": {
    "autoApply": true
  },
  "installation": {
    "user": "openclaw",
    "group": "openclaw",
    "configDir": "/home/openclaw/.openclaw",
    "workspaceDir": "/home/openclaw/.openclaw/workspace",
    "skillsDir": "/home/openclaw/.openclaw/skills"
  },
  "skills": {
    "repository": "https://github.com/Heretek-AI/heretek-skills.git",
    "branch": "main",
    "autoUpdate": false
  },
  "systemd": {
    "enable": false,
    "autoStart": false
  },
  "model": {
    "provider": "ollama",
    "defaultModel": "qwen3.5:cloud",
    "defaultUrl": "http://localhost:11434"
  }
}